# ════════════════════════════════════════════════════════════════════════════
# Worker image — reuses the same multi-stage build as the API image.
# The only difference is the CMD entrypoint: runs worker.py instead of uvicorn.
# Build: docker build -f Dockerfile.worker -t codepilot-worker .
# ════════════════════════════════════════════════════════════════════════════
FROM python:3.11-slim AS builder

WORKDIR /build

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN pip install --no-cache-dir \
    "torch>=2.4,<2.6" \
    --index-url https://download.pytorch.org/whl/cpu

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

RUN pip uninstall -y kubernetes networkx pip setuptools wheel 2>/dev/null || true

# ════════════════════════════════════════════════════════════════════════════
FROM python:3.11-slim AS final

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl \
    && git --version \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1001 appgroup \
    && useradd --uid 1001 --gid appgroup --shell /bin/bash --create-home appuser

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY . .

RUN mkdir -p /app/repos /app/embeddings /app/vector_store \
    && chown -R appuser:appgroup /app

ENV GIT_PYTHON_REFRESH=quiet

USER appuser

# Worker health check — verifies the Python process can import core modules
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD python -c "from services.redis_service import dequeue_indexing_task" || exit 1

CMD ["python", "worker.py"]
